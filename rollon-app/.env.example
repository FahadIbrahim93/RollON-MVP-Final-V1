# API Configuration
VITE_API_URL=http://localhost:4000/api

# Payment Gateway — Bangladesh
# Get credentials from: https://sslcommerz.com/
VITE_SSLCOMMERZ_STORE_ID=your_store_id_here
VITE_SSLCOMMERZ_STORE_PASSWORD=your_store_password_here
# Get credentials from: https://developer.bkash.com/
VITE_BKASH_APP_KEY=your_bkash_app_key_here
VITE_BKASH_APP_SECRET=your_bkash_app_secret_here

# App Locale
VITE_CURRENCY=BDT
VITE_CURRENCY_SYMBOL=৳
VITE_LOCALE=bn-BD

# Error Tracking
# Get DSN from: https://sentry.io/
VITE_SENTRY_DSN=your_sentry_dsn_here

# Analytics
# Get key from: https://posthog.com/
VITE_POSTHOG_KEY=your_posthog_key_here

# Demo Users
VITE_DEMO_ADMIN_EMAIL=admin@rollon.com
VITE_DEMO_ADMIN_PASSWORD=admin_password_here
VITE_DEMO_USER_EMAIL=customer@example.com
VITE_DEMO_USER_PASSWORD=user_password_here
