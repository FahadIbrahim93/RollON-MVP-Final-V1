{
  "$schema": "https://app.kilo.ai/config.json",
  "permission": {
    "bash": {
      "npm *": "allow",
      "npm run *": "allow",
      "git *": "allow",
      "ls *": "allow",
      "cat *": "allow",
      "grep *": "allow",
      "echo *": "allow"
    },
    "edit": {
      "**/*.ts": "allow",
      "**/*.tsx": "allow",
      "**/*.json": "allow"
    }
  }
}